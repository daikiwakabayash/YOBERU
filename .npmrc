# Vercel ビルドで `npm install` が CPU 制限 (exit 152 = SIGXCPU) で
# 落ちる事象への対策。
#
# - legacy-peer-deps: React 19 / Next 16 周辺の peer dep 解決ループを
#   抑え、npm が長時間 lock 探索をしないようにする。
# - audit / fund: CI では走らせる必要がない (warning だけ消す)。
# - prefer-offline: 既存の cache を優先することで初回以外を高速化。
legacy-peer-deps=true
audit=false
fund=false
prefer-offline=true
