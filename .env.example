NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# メール送信 (Resend)
# ---------------------------------------------------------------------------
# リマインドメール / 予約確認メール の送信に使う。
# https://resend.com/api-keys で発行した API キーを設定。
RESEND_API_KEY=re_your_api_key_here

# 送信元アドレス。yurumu8.net のように「自社ドメインで verified 済」の
# アドレスを指定する。Gmail / Yahoo 等の無料ドメインを使うと 2024 年以降
# の新基準で迷惑メール行きになりやすい。
YOBERU_MAIL_FROM=noreply@yurumu8.net

# 迷惑メール対策のため、Resend ダッシュボードで送信ドメインを Verify し、
# ドメインレジストラに以下の DNS レコードを追加する必要がある:
#
#   1. SPF (TXT "v=spf1 include:amazonses.com ~all" など Resend が指示する値)
#   2. DKIM (CNAME 3 本。Resend が指示するホスト名/値をそのまま設定)
#   3. DMARC (TXT "v=DMARC1; p=none; rua=mailto:postmaster@yurumu8.net" から開始)
#
# Verify が完了していないと sendEmail は 403 を返す。

# ---------------------------------------------------------------------------
# Cron 認可
# ---------------------------------------------------------------------------
# /api/cron/send-reminders を外部 cron から呼ぶ際の Bearer トークン。
# Vercel Cron を使う場合は空でも動くが、公開 URL なので設定推奨。
CRON_SECRET=your-cron-secret
