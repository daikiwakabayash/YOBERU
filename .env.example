# ============================================================================
# YOBERU サロン予約管理システム - 環境変数サンプル
# ============================================================================
# Vercel ダッシュボードで Settings → Environment Variables から登録する。
#   * Production / Preview / Development の 3 環境を分けて設定可。
#   * 機密値 (Secret / Access Token) は "Sensitive" トグルを ON にする。
# ローカル開発時は本ファイルをコピーして `.env.local` を作成し、値を差し替え。
# ============================================================================

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Supabase ダッシュボード → Project Settings → API から取得。
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# アプリ公開 URL (オプション)
# ---------------------------------------------------------------------------
# LINE 通知 / メール本文の埋め込みリンクのベース URL。
# 未設定なら https://yoberu.example.com がフォールバック値。
# 本番: 独自ドメイン or Vercel デフォルトドメイン
#   例) https://yoberu-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app

# ---------------------------------------------------------------------------
# メール送信 (Resend)
# ---------------------------------------------------------------------------
# リマインドメール / 予約確認メール の送信に使う。
# https://resend.com/api-keys で発行した API キーを設定。
RESEND_API_KEY=re_your_api_key_here

# 送信元アドレス。yurumu8.net のように「自社ドメインで verified 済」の
# アドレスを指定する。Gmail / Yahoo 等の無料ドメインを使うと 2024 年以降
# の新基準で迷惑メール行きになりやすい。
YOBERU_MAIL_FROM=noreply@yurumu8.net

# 迷惑メール対策のため、Resend ダッシュボードで送信ドメインを Verify し、
# ドメインレジストラに以下の DNS レコードを追加する必要がある:
#
#   1. SPF (TXT "v=spf1 include:amazonses.com ~all" など Resend が指示する値)
#   2. DKIM (CNAME 3 本。Resend が指示するホスト名/値をそのまま設定)
#   3. DMARC (TXT "v=DMARC1; p=none; rua=mailto:postmaster@yurumu8.net" から開始)
#
# Verify が完了していないと sendEmail は 403 を返す。

# ---------------------------------------------------------------------------
# Cron 認可
# ---------------------------------------------------------------------------
# /api/cron/send-reminders を外部 cron から呼ぶ際の Bearer トークン。
# Vercel Cron を使う場合は空でも動くが、公開 URL なので設定推奨。
# 生成例: `openssl rand -hex 32`
CRON_SECRET=your-cron-secret

# ---------------------------------------------------------------------------
# LINE 連携 (Messaging API + LIFF)
# ---------------------------------------------------------------------------
# 店舗ごとの Channel ID / Secret / Access Token は `shops` テーブルに保存
# されるため env には入れない (多店舗で異なるため)。店舗設定画面から入力。
#
# env に入れるのは以下 3 つ (LIFF 周り):
#
# 1. NEXT_PUBLIC_LINE_LIFF_ID
#    LINE Developers Console → LINE Login チャネル → LIFF タブで発行する ID。
#    リッチメニューから `/line/liff` を開いたときに `liff.init()` が使う。
#    クライアント側で使うため `NEXT_PUBLIC_` プレフィックス必須。
NEXT_PUBLIC_LINE_LIFF_ID=1234567890-xxxxxxxx

# 2. NEXT_PUBLIC_DEFAULT_BOOK_SLUG (オプション)
#    リッチメニュー「予約」ボタンの遷移先となるデフォルトの booking_links.slug。
#    未設定ならトップページへリダイレクトする。
NEXT_PUBLIC_DEFAULT_BOOK_SLUG=default

# 3. LIFF_LINK_SECRET
#    予約完了画面 → LIFF 経由で「この LINE userId をこの予約の顧客に
#    紐付ける」ためのトークン署名鍵 (HMAC-SHA256)。漏えいすると他人の
#    予約に勝手に紐付けできるため、十分長いランダム文字列を使う。
#    例: openssl rand -hex 32
#    未設定の場合は CRON_SECRET をフォールバックで使う。両方無いと
#    予約完了画面の「LINE 連携」ボタンは表示されない (= 機能 OFF)。
LIFF_LINK_SECRET=

# ---------------------------------------------------------------------------
# LINE 連携 - 設定手順 (LINE Developers Console)
# ---------------------------------------------------------------------------
# https://developers.line.biz/console/
#
# 1. Provider を作成 (既にあれば skip)
#
# 2. Messaging API チャネルを作成
#    - ボット基本 ID / Channel ID / Channel Secret / Channel Access Token を取得
#    - Access Token は「Issue」ボタンで発行 (1 度しか表示されない → コピー必須)
#    - → 管理画面「店舗」→ 該当店舗の line_channel_id / secret / access_token
#      に貼り付け (DB の shops テーブルに保存される)
#    - Webhook URL を登録:
#         https://<your-vercel-domain>/api/line/webhook
#      "Use webhook" を ON / "応答メッセージ" を OFF
#
# 3. LINE Login チャネルを作成 (LIFF 用)
#    - Channel ID / Secret を取得 (※現時点では server 側で未使用。v2 で追加予定)
#    - LIFF アプリを追加:
#         Endpoint URL: https://<your-vercel-domain>/line/liff
#         Scope: profile, openid
#         Size: Full
#    - 発行された LIFF ID を NEXT_PUBLIC_LINE_LIFF_ID に設定
#
# 4. リッチメニューをインストール (オプション)
#    本リポジトリの scripts/setup-line-rich-menu.ts を使う:
#      npx ts-node scripts/setup-line-rich-menu.ts \
#        --token=<LINE_CHANNEL_ACCESS_TOKEN> \
#        --base=https://<your-vercel-domain> \
#        --image=./rich-menu.png
